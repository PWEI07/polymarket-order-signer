# === REQUIRED (you fill these in) ===

# Your EOA wallet private key (0x + 64 hex chars).
# Export from MetaMask/Rabby: Account Details > Export Private Key.
PRIVATE_KEY=0x_your_eoa_private_key_here

# Relayer API Key from polymarket.com/settings > API Keys.
# Canonical name (also accepted: relay_api_key)
RELAY_API_KEY=your-relay-api-key

# The EOA address that owns the Relayer API Key (same settings page).
# Canonical name (also accepted: relay_api_key_address)
RELAY_API_KEY_ADDRESS=0x_your_eoa_address

# === AUTO-FILLED BY SETUP (do not edit manually) ===
# DEPOSIT_WALLET=
# CLOB_API_KEY=
# CLOB_API_SECRET=
# CLOB_API_PASSPHRASE=

# === OPTIONAL TUNING ===

SIGNATURE_TYPE=3

# Auth token for the signer API. Change this to a long random string.
ORDER_SIGNER_AUTH_TOKEN=change-me-to-a-random-secret

# Set to false and list specific token IDs to restrict which markets can be traded.
ORDER_SIGNER_ALLOW_ANY_TOKEN=true
# ALLOWED_TOKEN_IDS=token1,token2,token3

# Order size limits.
# MAX_ORDER_NOTIONAL_USD=10
# MAX_ORDER_SIZE=100
